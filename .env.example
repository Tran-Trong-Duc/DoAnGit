# Copy this file to .env and fill in your values.

# Gemini API for ChatBot. If this is missing or fails, ChatBot answers from MySQL knowledge.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Max conversation messages sent to the model (0 = unlimited)
AI_DEMO_CONTEXT_MESSAGE_LIMIT=80

# Max characters per message
AI_DEMO_MAX_MESSAGE_CHARS=4200

# Max tokens in assistant reply
AI_DEMO_MAX_OUTPUT_TOKENS=2000

# AI request timeout (ms)
AI_ASSISTANT_TIMEOUT_MS=25000

# Garden DB timeout (ms)
PLANT_ASSISTANT_DB_TIMEOUT_MS=3000

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=iot_garden

# Google CSE for the internal search box. Only CX is used.
GOOGLE_CSE_CX=YOUR_GOOGLE_CSE_CX_HERE
